<fonts-modification version="1">
    <family customizationType="new-named-family" name="rohie-sans">
        <font weight="100" style="normal">Rohie-Thin.ttf</font>
        <font weight="100" style="italic">Rohie-ThinItalic.ttf</font>
        <font weight="300" style="normal">Rohie-Light.ttf</font>
        <font weight="300" style="italic">Rohie-LightItalic.ttf</font>
        <font weight="400" style="normal">Rohie-Regular.ttf</font>
        <font weight="400" style="italic">Rohie-Italic.ttf</font>
        <font weight="500" style="normal">Rohie-Medium.ttf</font>
        <font weight="500" style="italic">Rohie-MediumItalic.ttf</font>
        <font weight="700" style="normal">Rohie-Bold.ttf</font>
        <font weight="700" style="italic">Rohie-BoldItalic.ttf</font>
        <font weight="900" style="normal">Rohie-Black.ttf</font>
        <font weight="900" style="italic">Rohie-BlackItalic.ttf</font>
    </family>
    <alias name="rohie-sans-medium" to="rohie-sans" weight="500" />

</fonts-modification>
